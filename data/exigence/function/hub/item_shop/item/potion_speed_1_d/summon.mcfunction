$data merge entity @s {Item:{id:"minecraft:potion",count:1,components:{"minecraft:custom_name":[{text:"🧪",italic:false,bold:true,color:"white"},\
{text:" Prolonged Swiftness ",italic:false,bold:true,color:"$(rare)"},{text:"🧪",italic:false,bold:true,color:"white"}]\
,"minecraft:tooltip_display":{hidden_components:["potion_contents"]}\
,"minecraft:potion_contents":{custom_color:$(speed)}\
,"minecraft:lore":[[$(rare_stars),{text:"Speed Potion",italic:false,color:"white"}],{text:""}\
,[{text:"Speed I ",italic:false,color:"$(effect)"},{text:"(04:00)",italic:false,color:"gray"}]\
],"minecraft:custom_data":{item_name:"potion_speed_1_d",check_holding:true}}}}
