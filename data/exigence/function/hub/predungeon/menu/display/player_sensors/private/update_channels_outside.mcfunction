# Update the glowing channel door

## CONSTRAINTS
#   AS inv channel

#====================================================================================================

execute if score #sensor_state Temp matches 0 run data modify entity @s Glowing set value false
execute if score #sensor_state Temp matches 1 run data modify entity @s Glowing set value true

