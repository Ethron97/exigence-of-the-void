# Update the dead channel door

## CONSTRAINTS
#   AS main channel

#====================================================================================================

execute if score #sensor_state Temp matches 0 run data modify entity @s item.components."minecraft:enchantments" set value {protection:1}
execute if score #sensor_state Temp matches 1 run data remove entity @s item.components."minecraft:enchantments"

execute if score #sensor_state Temp matches 0 run return run data modify entity @s item.components."minecraft:custom_model_data".strings set value ["channel_inside_0"]
