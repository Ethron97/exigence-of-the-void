# Convert all placeholder void leggings

## CONSTRAINTS
#   AS player
#       If they have at least one leggings in inventory to convert

#====================================================================================================

execute if items entity @s weapon.offhand netherite_nautilus_armor[custom_data~{item_name:"leggings_artifact"}] run item modify entity @s weapon.offhand exigence:void_armor/convert_leggings

